# Pipeline API Keys
# -----------------
# Copy this file to .env and fill in your keys.
# Never commit .env to version control.
#
# HOW TO GET EACH KEY:
#
# OPENALEX_API_KEY
#   Required since Feb 13, 2026. Free.
#   → https://openalex.org/settings/api (create free account first)
#
# NCBI_API_KEY (PubMed)
#   Optional but recommended. Free. Increases rate limit 3x → 10 req/s.
#   → https://www.ncbi.nlm.nih.gov/account/ (create NCBI account)
#   → Settings → API Key Management → Create API Key
#
# NCBI_EMAIL
#   Required by NCBI terms of use (even without API key).
#   Just your email address — identifies your script to NCBI.
#
# SEMANTIC_SCHOLAR_API_KEY
#   Optional. Free on request. Gives dedicated 1 req/s vs shared pool.
#   → https://www.semanticscholar.org/product/api (request form)
#
# CORE_API_KEY
#   Optional. Free registration. Higher rate limits.
#   → https://core.ac.uk/services/api (register for free key)
#
# PHILPAPERS_API_ID and PHILPAPERS_API_KEY
#   Required for full API access. Free registration.
#   → https://philpapers.org/utils/create_api_user.html
#
# ANTHROPIC_API_KEY
#   Required for Claude API (primary LLM).
#   → https://console.anthropic.com

# GOOGLE_BOOKS_API_KEY
#   Optional but recommended. Free quota is 1000 req/day without key.
#   With key: 1000 req/day on free tier, more on paid.
#   → console.cloud.google.com → Enable "Books API" → Credentials → Create API Key

GOOGLE_BOOKS_API_KEY=
NCBI_API_KEY=
NCBI_EMAIL=your@email.com
SEMANTIC_SCHOLAR_API_KEY=
CORE_API_KEY=
PHILPAPERS_API_ID=
PHILPAPERS_API_KEY=
ANTHROPIC_API_KEY=
